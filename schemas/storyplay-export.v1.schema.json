{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storyplay.local/schemas/storyplay-export.v1.schema.json",
  "title": "StoryPlay game export (v1)",
  "description": "Canonical export document for a StoryPlay story. Matches in-app story state shape: variables + React Flow-style nodes. Edges are derived from node.data.choices and are not stored.",
  "type": "object",
  "additionalProperties": false,
  "required": ["formatVersion", "story"],
  "properties": {
    "formatVersion": {
      "type": "integer",
      "const": 1,
      "description": "Export format revision. Importers must reject or migrate unknown versions."
    },
    "exportedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the file was written (optional, recommended)."
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "description": "Author-facing metadata. Does not affect engine rules unless a consumer chooses to use it.",
      "properties": {
        "title": {
          "type": "string",
          "description": "Human-readable story title (not necessarily any node title)."
        },
        "author": { "type": "string" },
        "description": { "type": "string" },
        "startNodeId": {
          "type": "string",
          "description": "Suggested entry node id. Must match a node.id. If omitted, runtimes may use nodes[0] or data.isStart as today’s app does for diagnostics only."
        }
      }
    },
    "story": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variables", "nodes"],
      "description": "Same shape as useStoryState / sampleStory: global variables plus the node graph.",
      "properties": {
        "variables": {
          "type": "object",
          "description": "Initial variable store. Trait pickers and choice weighting may store arrays or objects, so values may be any JSON value.",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        },
        "variableMeta": {
          "type": "object",
          "description": "Optional player-facing labels and descriptions for variables.",
          "additionalProperties": { "$ref": "#/$defs/variableMeta" }
        },
        "characters": {
          "type": "array",
          "description": "Reusable character registry for {{character:id.name}} reference tokens in node and choice text.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "aliases": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "nodes": {
          "type": "array",
          "description": "Ordered list of story blocks. Each item is a React Flow-compatible node.",
          "items": { "$ref": "#/$defs/storyNode" }
        }
      }
    }
  },
  "$defs": {
    "jsonPrimitive": {
      "type": ["string", "number", "boolean", "null"]
    },
    "jsonValue": {
      "anyOf": [
        { "$ref": "#/$defs/jsonPrimitive" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/jsonValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        }
      ]
    },
    "variableMeta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "playerLabel": { "type": "string" },
        "playerDescription": { "type": "string" },
        "icon": { "type": "string" }
      }
    },
    "storyNode": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "data"],
      "description": "React Flow node. type and position are preserved for editor round-trip; runtimes may ignore position.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable unique id referenced by choices.targetNodeId, timeoutTargetNodeId, successNodeId, etc."
        },
        "type": {
          "type": "string",
          "default": "storyNode",
          "description": "Canvas node type; app uses \"storyNode\"."
        },
        "position": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "description": "Editor canvas coordinates."
        },
        "data": { "$ref": "#/$defs/nodeData" }
      }
    },
    "nodeData": {
      "oneOf": [
        { "$ref": "#/$defs/narrativeNodeData" },
        { "$ref": "#/$defs/chatNodeData" },
        { "$ref": "#/$defs/timedNodeData" },
        { "$ref": "#/$defs/endingNodeData" },
        { "$ref": "#/$defs/traitPickerNodeData" },
        { "$ref": "#/$defs/persuasionNodeData" },
        { "$ref": "#/$defs/choiceWeightingNodeData" },
        { "$ref": "#/$defs/legacyNodeData" },
        { "$ref": "#/$defs/unknownNodeData" }
      ]
    },
    "nodeDataBase": {
      "type": "object",
      "additionalProperties": true,
      "description": "Block payload. blockType selects which other fields are meaningful. Unknown keys may appear for forward compatibility.",
      "properties": {
        "title": { "type": "string", "description": "Block heading in UI." },
        "content": {
          "type": "string",
          "description": "Primary text: narrative body, chat script (lines; lines starting with \"You:\" are outgoing), or mini-game prompt stored alongside blockType."
        },
        "blockType": {
          "type": "string",
          "description": "Discriminator for preview/runtime behavior. Known values receive block-specific validation; unknown strings remain forward compatible."
        },
        "choices": {
          "type": "array",
          "description": "Block-specific rows. Concrete nodeData branches select branching choices, chat replies, or persuasion lines.",
          "items": { "type": "object" }
        },
        "enterEffects": {
          "type": "array",
          "items": { "$ref": "#/$defs/effect" },
          "description": "Effects intended when entering a node (present in model and diagnostics; runtime may not apply them yet)."
        },
        "graphIssues": {
          "type": "array",
          "description": "Editor diagnostics from graph analysis. Clean exports often omit or set to [].",
          "items": { "type": "object", "additionalProperties": true }
        },
        "isStart": {
          "type": "boolean",
          "description": "Optional hint for diagnostics / future start resolution."
        },
        "behavior": {
          "type": "object",
          "description": "Reserved node behavior payload; default { kind: \"none\", config: {} }.",
          "additionalProperties": true
        },
        "prompt": {
          "type": "string",
          "description": "Optional mini-game prompt. Existing blocks may use content instead."
        },
        "submitLabel": {
          "type": "string",
          "description": "Optional mini-game submit button label."
        },
        "timerSeconds": {
          "type": "number",
          "description": "timed blocks: countdown length in seconds."
        },
        "timeoutTargetNodeId": {
          "type": "string",
          "description": "timed blocks: node id to jump to when timer expires."
        },
        "timeoutEffects": {
          "type": "array",
          "items": { "$ref": "#/$defs/effect" },
          "description": "timed blocks: effects applied on timeout navigation."
        },
        "continueNodeId": {
          "type": "string",
          "description": "traitPicker / choiceWeighting: node id to visit after completion."
        },
        "minSelections": {
          "type": "number",
          "description": "traitPicker: minimum traits to select."
        },
        "maxSelections": {
          "type": "number",
          "description": "traitPicker: maximum traits selectable."
        },
        "traitListVariable": {
          "type": "string",
          "description": "traitPicker: variable name receiving selected trait ids (array)."
        },
        "options": {
          "type": "array",
          "description": "traitPicker / choiceWeighting: option rows (see $defs/traitOption and $defs/weightedOption).",
          "items": { "type": "object", "additionalProperties": true }
        },
        "targetName": {
          "type": "string",
          "description": "persuasion: NPC or subject label."
        },
        "startScore": { "type": "number", "description": "persuasion: initial score." },
        "minScore": { "type": "number" },
        "maxScore": { "type": "number" },
        "threshold": { "type": "number", "description": "persuasion: score needed to pass." },
        "maxTurns": { "type": "number" },
        "visibleMeter": { "type": "boolean" },
        "scoreVariable": { "type": "string" },
        "successVariable": { "type": "string" },
        "successNodeId": {
          "type": "string",
          "description": "persuasion: node id when passed (also used at block level; lines may carry overrides in editor data)."
        },
        "failureNodeId": { "type": "string", "description": "persuasion: node id when failed." },
        "autoAdvance": {
          "type": "boolean",
          "description": "persuasion: if true, PersuasionBlockView may finish immediately when outcome is known."
        },
        "totalPoints": { "type": "number", "description": "choiceWeighting: point budget." },
        "variablePrefix": {
          "type": "string",
          "description": "choiceWeighting: prefix for per-option variable keys written on complete."
        },
        "resultVariable": {
          "type": "string",
          "description": "choiceWeighting: variable receiving allocation object."
        },
        "lockExactTotal": {
          "type": "boolean",
          "description": "choiceWeighting: require exact point spend to submit."
        }
      }
    },
    "narrativeNodeData": {
      "allOf": [
        { "$ref": "#/$defs/nodeDataBase" },
        {
          "properties": {
            "blockType": { "const": "narrative" },
            "choices": {
              "type": "array",
              "items": { "$ref": "#/$defs/branchingChoice" }
            }
          },
          "required": ["blockType"]
        }
      ]
    },
    "chatNodeData": {
      "allOf": [
        { "$ref": "#/$defs/nodeDataBase" },
        {
          "properties": {
            "blockType": { "const": "chat" },
            "choices": {
              "type": "array",
              "items": {
                "anyOf": [
                  { "$ref": "#/$defs/chatReply" },
                  { "$ref": "#/$defs/branchingChoice" }
                ]
              }
            }
          },
          "required": ["blockType"]
        }
      ]
    },
    "timedNodeData": {
      "allOf": [
        { "$ref": "#/$defs/nodeDataBase" },
        {
          "properties": {
            "blockType": { "const": "timed" },
            "choices": {
              "type": "array",
              "items": { "$ref": "#/$defs/branchingChoice" }
            }
          },
          "required": ["blockType"]
        }
      ]
    },
    "endingNodeData": {
      "allOf": [
        { "$ref": "#/$defs/nodeDataBase" },
        {
          "properties": {
            "blockType": { "const": "ending" },
            "choices": {
              "type": "array",
              "items": { "$ref": "#/$defs/branchingChoice" }
            }
          },
          "required": ["blockType"]
        }
      ]
    },
    "traitPickerNodeData": {
      "allOf": [
        { "$ref": "#/$defs/nodeDataBase" },
        {
          "properties": {
            "blockType": { "const": "traitPicker" },
            "options": {
              "type": "array",
              "items": { "$ref": "#/$defs/traitOption" }
            }
          },
          "required": ["blockType"]
        }
      ]
    },
    "persuasionNodeData": {
      "allOf": [
        { "$ref": "#/$defs/nodeDataBase" },
        {
          "properties": {
            "blockType": { "const": "persuasion" },
            "choices": {
              "type": "array",
              "items": { "$ref": "#/$defs/persuasionLine" }
            }
          },
          "required": ["blockType"]
        }
      ]
    },
    "choiceWeightingNodeData": {
      "allOf": [
        { "$ref": "#/$defs/nodeDataBase" },
        {
          "properties": {
            "blockType": { "const": "choiceWeighting" },
            "options": {
              "type": "array",
              "items": { "$ref": "#/$defs/weightedOption" }
            }
          },
          "required": ["blockType"]
        }
      ]
    },
    "legacyNodeData": {
      "allOf": [
        { "$ref": "#/$defs/nodeDataBase" },
        {
          "properties": {
            "blockType": false,
            "choices": {
              "type": "array",
              "items": { "$ref": "#/$defs/branchingChoice" }
            }
          }
        }
      ]
    },
    "unknownNodeData": {
      "allOf": [
        { "$ref": "#/$defs/nodeDataBase" },
        {
          "properties": {
            "blockType": {
              "type": "string",
              "not": {
                "enum": [
                  "narrative",
                  "chat",
                  "timed",
                  "ending",
                  "traitPicker",
                  "persuasion",
                  "choiceWeighting"
                ]
              }
            }
          },
          "required": ["blockType"]
        }
      ]
    },
    "choiceBase": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/condition" }
        },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/effect" }
        }
      }
    },
    "branchingChoice": {
      "allOf": [
        { "$ref": "#/$defs/choiceBase" },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "label": { "type": "string" },
            "choiceKind": { "const": "goTo" },
            "targetNodeId": { "type": "string" }
          }
        }
      ],
      "description": "Branching choice. targetNodeId may be empty while authoring."
    },
    "chatReply": {
      "allOf": [
        { "$ref": "#/$defs/choiceBase" },
        {
          "anyOf": [
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "label": { "type": "string" },
                "choiceKind": { "const": "chatReply" },
                "playerMessage": { "type": "string" },
                "npcResponse": { "type": "string" }
              },
              "required": ["npcResponse"]
            },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "label": { "type": "string" },
                "choiceKind": { "const": "chatReply" },
                "playerMessage": { "type": "string" },
                "npcResponse": { "type": "string" }
              },
              "required": ["choiceKind"]
            }
          ]
        }
      ],
      "description": "Chat reply. Legacy files may omit choiceKind when npcResponse identifies the row."
    },
    "persuasionLine": {
      "allOf": [
        { "$ref": "#/$defs/choiceBase" },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "text": { "type": "string" },
            "delta": { "type": "number" },
            "once": { "type": "boolean" },
            "response": { "type": "string" },
            "successNodeId": { "type": "string" },
            "failureNodeId": { "type": "string" }
          },
          "required": ["text", "delta"]
        }
      ]
    },
    "choice": {
      "description": "Deprecated compatibility alias for the former combined choice definition.",
      "anyOf": [
        { "$ref": "#/$defs/branchingChoice" },
        { "$ref": "#/$defs/chatReply" },
        { "$ref": "#/$defs/persuasionLine" }
      ]
    },
    "legacyChoiceProperties": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "choiceKind": {
          "type": "string",
          "enum": ["chatReply", "goTo"],
          "description": "Chat blocks: chatReply runs a player/NPC turn; goTo leaves the chat."
        },
        "playerMessage": {
          "type": "string",
          "description": "Chat reply: optional player bubble text. Falls back to label when empty."
        },
        "npcResponse": {
          "type": "string",
          "description": "Chat reply: NPC lines after the player speaks (Name: message format)."
        },
        "targetNodeId": { "type": "string", "description": "Branching: destination node id." },
        "text": { "type": "string", "description": "persuasion: line button text." },
        "delta": { "type": "number", "description": "persuasion: score change." },
        "once": { "type": "boolean" },
        "response": { "type": "string" },
        "successNodeId": { "type": "string", "description": "Optional per-line overrides in editor normalization (runtime uses block-level ids)." },
        "failureNodeId": { "type": "string" }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variable", "operator", "value"],
      "properties": {
        "variable": { "type": "string" },
        "operator": {
          "type": "string",
          "enum": [
            "equals",
            "notEquals",
            "greaterThan",
            "lessThan",
            "greaterThanOrEqual",
            "lessThanOrEqual"
          ]
        },
        "value": {
          "$ref": "#/$defs/jsonPrimitive",
          "description": "Compared against variables[variable]; type should match variable type for sensible results."
        }
      }
    },
    "effect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variable", "action"],
      "properties": {
        "variable": { "type": "string" },
        "action": {
          "type": "string",
          "enum": ["set", "add", "subtract", "toggle"]
        },
        "value": {
          "$ref": "#/$defs/jsonValue",
          "description": "Required for set/add/subtract; toggle ignores value in storyLogic."
        }
      }
    },
    "traitOption": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "value": { "type": "string" },
        "description": { "type": "string" },
        "effects": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" },
          "description": "Optional variable patch map applied when trait is selected (TraitPickerBlockView)."
        }
      }
    },
    "weightedOption": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "value": { "type": "number" },
        "correct": { "type": "boolean" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/effect" },
          "description": "Editor-normalized effects on option (if present)."
        }
      }
    }
  }
}
